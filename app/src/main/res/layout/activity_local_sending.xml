<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/secondary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Локальная отправка"
        app:titleTextColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Network Status Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/secondary"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivWifiIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check"
                app:tint="#3390EC" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNetworkName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Сеть: Home_WiFi"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Поиск устройств в сети..."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Device List Header -->
    <TextView
        android:id="@+id/tvDevicesHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="Доступные устройства"
        android:textColor="#3390EC"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/statusCard"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- RecyclerView for Devices -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDevices"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvDevicesHeader"
        app:layout_constraintBottom_toTopOf="@id/selectionCard" />

    <!-- File Selection Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/selectionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/secondary"
        app:cardCornerRadius="24dp"
        app:layout_constraintBottom_toTopOf="@id/swipeContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSelectedInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выбрано: 0 файлов (0 Мб)"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Выбрать данные"
                app:cornerRadius="16dp"
                android:backgroundTint="#1A3390EC"
                android:textColor="#3390EC"
                app:icon="@android:drawable/ic_menu_add"
                app:iconTint="#3390EC" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/swipeContainer"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:background="@drawable/bg_swipe_track"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Отправить архив"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/swipeThumb"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="5dp"
            app:cardBackgroundColor="#3390EC"
            app:cardCornerRadius="27dp"
            app:cardElevation="4dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_up"
                android:rotation="90"
                app:tint="@color/white" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>